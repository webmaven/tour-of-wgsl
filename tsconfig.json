{
  "compilerOptions": {
    "outDir": "resources/js",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noEmit": true,
    "lib": ["es2020", "dom"],
    "typeRoots": ["./node_modules/@webgpu/types", "./node_modules/@types"]
  },
  "include": ["assets/ts/**/*.ts"],
  "typedocOptions": {
    "treatWarningsAsErrors": true,
    "treatValidationWarningsAsErrors": true,
    "entryPointStrategy": "expand",
    "entryPoints": ["assets/ts/"],
    "excludeInternal": false,
    "excludeProtected": true,
    "excludePrivate": true,
    "excludeNotDocumentedKinds": [],
    "out": "docs/typedoc",
    "requiredToBeDocumented": [
      "Enum",
      "EnumMember",
      "Variable",
      "Function",
      "Class",
      "Interface",
      "Property",
      "Method",
      "GetSignature",
      "SetSignature",
      "TypeAlias",
      "Module",
      "Namespace",
      "Project",
      "Constructor",
      "Parameter"
    ],
    "validation": {
      "notExported": true,
      "invalidLink": true,
      "notDocumented": true
    }
  }
}
